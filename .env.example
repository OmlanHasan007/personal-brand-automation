# ============================================================
# Personal Brand Automation — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is in .gitignore.
# ============================================================

# --- Groq API (FREE — no credit card needed) ---
# Post generation, cover letters, interview coach
# Get key at: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_key_here

# --- Gemini API (FREE — no credit card needed) ---
# Paper summaries, README updates, bulk tasks
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_gemini_key_here

# --- GitHub ---
# Create token at: https://github.com/settings/tokens
# Required scopes: repo, read:user
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_USERNAME=your_github_username

# --- LinkedIn OAuth 2.0 ---
# Create app at: https://www.linkedin.com/developers/apps
# Required permissions: w_member_social, openid, profile, email
# Add redirect URI in app settings: http://localhost:8080/callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=          # Filled automatically after: python main.py auth-linkedin
LINKEDIN_PERSON_URN=            # Filled automatically after: python main.py auth-linkedin

# --- ChatGPT Go (your subscription) ---
# No API key needed — you use this manually in the browser.
# Workflow: draft auto-generated → you refine in ChatGPT Go → publish

# --- App settings ---
LOG_LEVEL=INFO
